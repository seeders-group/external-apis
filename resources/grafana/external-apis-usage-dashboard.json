      "title": "Total Consumption (Units)",
      "type": "stat",
      "targets": [{ "expr": "sum(${namespace}_api_logs_consumption_total{integration=~\"$api_integration\", scope=~\"$scope\"})", "legendFormat": "", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "mappings": [], "noValue": "0" } },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 41 },
      "id": 22,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
