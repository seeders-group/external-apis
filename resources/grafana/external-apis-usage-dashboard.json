      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 100 }] }, "mappings": [], "noValue": "0" } },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 41 },
