      "title": "Total API Calls",
      "type": "stat",
      "targets": [{ "expr": "sum(${namespace}_api_logs_requests_total{integration=~\"$api_integration\", scope=~\"$scope\"})", "legendFormat": "", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }, { "color": "yellow", "value": 10000 }, { "color": "red", "value": 100000 }] }, "mappings": [] } },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 41 },
